# ===========================================
# Abiball Portal - Git Ignore
# ===========================================


# ----- Sensible Daten & Storage (NIEMALS committen!) -----
/abiball-portal/storage/

# ----- Logs -----
/abiball-portal/storage/*.log
/abiball-portal/var/cache/*
/abiball-portal/var/log/*

# ----- Composer (vendor kann via composer install wiederhergestellt werden) -----
/abiball-portal/vendor/

# ----- Umgebungsdateien -----
/abiball-portal/.env
/abiball-portal/.env.local

# ----- IDE & OS -----
.idea/
.vscode/
*.code-workspace
*.swp
*.swo
.DS_Store
Thumbs.db

# ----- Temporäre Dateien -----
*.tmp
*.bak
*~
