# .htaccess für Abiball Portal
# Apache 2.4+

# =========================================================
# Security Headers
# =========================================================

<IfModule mod_headers.c>
    # Verhindere Clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # Verhindere MIME-Type Sniffing
    Header always set X-Content-Type-Options "nosniff"
    
    # XSS-Schutz
    Header always set X-XSS-Protection "1; mode=block"
    
    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Permissions Policy
    Header always set Permissions-Policy "camera=(self), microphone=(), geolocation=(), interest-cohort=()"
    
    # Content Security Policy (anpassen nach Bedarf)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'self';"
    
    # HSTS (Strict Transport Security) - nur mit HTTPS aktivieren!
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS
</IfModule>

# =========================================================
# Performance: Browser Caching
# =========================================================

<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # CSS and JavaScript
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/x-javascript "access plus 1 month"
    
    # Fonts
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    
    # HTML (kein Caching für dynamische Inhalte)
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# =========================================================
# Compression
# =========================================================

<IfModule mod_deflate.c>
    # Komprimiere Text-basierte Inhalte
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE application/xml application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# =========================================================
# URL Rewriting (falls gewünscht)
# =========================================================

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # HTTPS erzwingen (nur aktivieren wenn SSL vorhanden!)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # Blockiere Zugriff auf versteckte Dateien
    RewriteRule "(^|/)\." - [F]
    
    # Blockiere Zugriff auf sensible Dateien
    RewriteRule "^(composer\.json|composer\.lock|\.env|\.gitignore)$" - [F,L]
</IfModule>

# =========================================================
# Verzeichnis-Schutz
# =========================================================

# Verhindere Directory Listing
Options -Indexes

# Blockiere Zugriff auf bestimmte Ordner
<IfModule mod_authz_core.c>
    <DirectoryMatch "^.*/\.(git|svn|storage|var|src)">
        Require all denied
    </DirectoryMatch>
</IfModule>

# Blockiere Zugriff auf PHP-Dateien in uploads/storage
<FilesMatch "\.(php|php3|php4|php5|phtml)$">
    <If "%{REQUEST_URI} =~ m#^/(storage|var)/#">
        Require all denied
    </If>
</FilesMatch>

# =========================================================
# Error Pages (optional - Seiten müssen erstellt werden)
# =========================================================

ErrorDocument 404 /404.php
ErrorDocument 500 /500.php
ErrorDocument 403 /404.php

# =========================================================
# PHP Settings (optional)
# =========================================================

<IfModule mod_php.c>
    # Erhöhe Memory Limit bei Bedarf
    # php_value memory_limit 256M
    
    # Session Security
    php_value session.cookie_httponly 1
    php_value session.cookie_secure 1
    php_value session.use_strict_mode 1
</IfModule>
