# CRITICAL: PARTICIPANT DATA PROTECTION
# Extra layer of protection for CSV files

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

<IfModule mod_access_compat.c>
    Order allow,deny
    Deny from all
</IfModule>

# Block direct CSV access
<FilesMatch "\.csv$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Disable PHP execution in this directory
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

AddType text/plain .csv .json
